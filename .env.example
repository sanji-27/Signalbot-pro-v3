# ─── TELEGRAM ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── SIGNAL THRESHOLDS ────────────────────────────────
MIN_CONFIDENCE=75          # Minimum confidence % to send signal (75-95)
ELITE_CONFIDENCE=88        # Elite/SureShot threshold
HIGH_QUALITY_ONLY=true     # Only send signals above ELITE_CONFIDENCE

# ─── RISK MANAGEMENT ──────────────────────────────────
MAX_RISK_PER_TRADE=1.0     # Max % of capital per trade
MAX_DAILY_RISK=3.0         # Max % daily drawdown allowed
MAX_CONSECUTIVE_LOSSES=2   # Stop after this many consecutive losses
CAPITAL=1000               # Starting capital (for position sizing)
STOP_LOSS_ATR_MULT=1.5     # Stop loss = ATR * this multiplier
TAKE_PROFIT_ATR_MULT=2.5   # TP1 = ATR * this

# ─── SCAN SETTINGS ────────────────────────────────────
SCAN_ENABLED=true
SCAN_INTERVAL_MIN=5        # Default scan interval (minutes)
# Comma-separated expiry durations to scan
SCAN_EXPIRIES=5,10,15,20,30,40,60

# ─── DATA SOURCES ─────────────────────────────────────
# Twelve Data API key (optional, for higher rate limits)
TWELVE_DATA_KEY=

# ─── WEB DASHBOARD ────────────────────────────────────
FLASK_PORT=5000
FLASK_SECRET_KEY=change_this_to_a_random_string

# ─── LOGGING ──────────────────────────────────────────
LOG_LEVEL=INFO
LOG_TO_FILE=true
DB_PATH=signals.db
